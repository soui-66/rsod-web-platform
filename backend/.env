# 应用基本信息
APP_NAME=RSOD Detection Platform
APP_VERSION=1.0.0
DEBUG=true

# PostgreSQL配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=rsod_user
DB_PASSWORD=your_secure_password
DB_NAME=rsod_db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rsod
MINIO_SECURE=false

# YOLO模型配置
YOLO_MODEL_PATH=models/yolo11n.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# 文件存储配置
UPLOAD_DIR=uploads
RESULT_DIR=results

# CORS配置
CORS_ORIGINS=["*"]


# JWT 密钥（生产环境请使用强随机密码）
SECRET_KEY=your-secret-key-here-change-in-production
JWT_EXPIRE_DAYS=30

# 数据库配置
DATABASE_URL=postgresql://rsod_user:rsod_password@localhost:5432/rsod_db

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-3d5ba132f03148a9845bf06b4b4bfc12